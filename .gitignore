# Ignore node_modules, which contains installed dependencies
node_modules/

# Ignore Parcel cache directory
.parcel-cache/

# Ignore local wrangler files
.wrangler/

# Ignore output directories
dist/
build/

# Ignore temporary files and system-specific files
.DS_Store
Thumbs.db

# Ignore logs
*.log
npm-debug.log*

# Ignore environment variable files
.env
.env.local

# Ignore IDE and editor specific files
.idea/
.vscode/
*.swp

# Ignore coverage reports
coverage/

# Ignore Parcel source maps
*.map
